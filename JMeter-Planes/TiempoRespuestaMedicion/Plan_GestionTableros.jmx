                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">{&#xd;
  &quot;fields&quot;: {&#xd;
    &quot;nombre&quot;: { &quot;stringValue&quot;: &quot;Tablero Masivo ${RANDOM_TABLERO_ID}&quot; },&#xd;
    &quot;creado&quot;: { &quot;timestampValue&quot;: &quot;${__time(yyyy-MM-dd&apos;T&apos;HH:mm:ss&apos;Z&apos;)}&quot; },&#xd;
    &quot;uid&quot;: { &quot;stringValue&quot;: &quot;${localId}&quot; }&#xd;
  }&#xd;
}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
          </HTTPSamplerProxy>
          <hashTree/>
